# ============================================================
# DeepSeek V4-Pro API 配置
# ============================================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_ID=deepseek-v4-pro

# ============================================================
# 联盟追踪后缀
# ============================================================
AFFILIATE_TAG=?tag=your-affiliate-tag-20

# ============================================================
# 网站公网 URL (Gitee Pages 或 GitHub Pages)
# ============================================================
SITE_URL=https://yourusername.gitee.io/honestgadgets

# ============================================================
# 手机报警通知 (二选一)
# PushDeer: https://www.pushdeer.com/
# Server酱: https://sct.ftqq.com/
# ============================================================
PUSH_DEER_KEY=PDUxxxxxx
SERVER_CHAN_KEY=SCTxxxxxx

# ============================================================
# 邮箱报警通知（推荐：QQ邮箱最方便）
# QQ邮箱: 登录 mail.qq.com → 设置 → 账户 → 开启SMTP → 获取授权码
# ============================================================
ALERT_EMAIL=你的QQ号
ALERT_EMAIL_AUTH=QQ邮箱授权码

# ============================================================
# 运行模式 (通过命令行参数控制，无需改 .env)
# 全量:      python auto_pilot.py
# 仅评测:    python auto_pilot.py --reviews-only
# 仅对比:    python auto_pilot.py --compare-only
# 预演:      python auto_pilot.py --dry-run
# ============================================================
